---
// src/layouts/BaseLayout.astro
interface Props {
  title?:       string;
  description?: string;
  ogImage?:     string;
}
const {
  title       = 'Fengqi Group | Cross-Border Industrial Platform',
  description = "Fengqi Group connects China and Southeast Asia through agriculture, logistics, industrial parks, trade and digital systems.",
  ogImage,
} = Astro.props;
---
<!doctype html>
<html lang="en">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <meta name="description" content={description} />
  <meta property="og:title"       content={title} />
  <meta property="og:description" content={description} />
  <meta property="og:type"        content="website" />
  {ogImage && <meta property="og:image" content={ogImage} />}
  <title>{title}</title>
  <link rel="icon" type="image/png" href="/images/logo/logo-circle.png" />
</head>
<body>
  <slot />
</body>
</html>
<style is:global>
  @import "../styles/global.css";
</style>
