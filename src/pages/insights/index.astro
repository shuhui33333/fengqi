---
// src/pages/insights/index.astro  →  /insights  (Storyblok)
import BaseLayout    from '../../layouts/BaseLayout.astro'
import Header        from '../../components/Header.astro'
import Footer        from '../../components/Footer.astro'
import ClientEffects from '../../components/ClientEffects.astro'
import { getAllInsights } from '../../lib/storyblok'

const posts = await getAllInsights().catch(() => [])

const DEFAULT_IMG = 'https://images.unsplash.com/photo-1504711434969-e33886168f5c?w=800&q=80'
---
<BaseLayout title="Insights | Fengqi Group" description="Latest news, project updates and industry perspectives from Fengqi Group.">
  <Header active="/insights" />
  <main>

    <!-- Hero -->
    <section class="ins-hero sec-dark section">
      <div class="geo-bg geo-bg--fade" style="opacity:.4"></div>
      <div class="wrap ins-hero-wrap">
        <div class="label label--dark">INSIGHTS</div>
        <h1>News &amp; <em>Updates</em>.</h1>
        <p class="body-text body-text--light body-text--wide">
          Latest developments, project milestones and industry perspectives from Fengqi Group.
        </p>
      </div>
    </section>

    <!-- Grid -->
    <section class="section sec-light" id="all-insights">
      <div class="wrap">
        {posts.length === 0 ? (
          <p class="ins-empty">No articles published yet — check back soon.</p>
        ) : (
          <div class="ins-grid">
            {posts.map((a, i) => {
              const imgSrc = a.image ?? DEFAULT_IMG
              return (
                <a href={`/insights/${a.slug}`} class={`ins-card reveal d${(i % 3) + 1}`}>
                  <!-- Image -->
                  <div class="ins-card-img">
                    <img src={imgSrc} alt={a.title} loading="lazy" />
                    <span class="ins-card-cat">{a.category}</span>
                  </div>
                  <!-- Content -->
                  <div class="ins-card-body">
                    <p class="ins-card-date">
                      {a.date.toLocaleDateString('en-GB', { year:'numeric', month:'long', day:'numeric' })}
                    </p>
                    <h3 class="ins-card-title">{a.title}</h3>
                    <p class="ins-card-sum">{a.summary}</p>
                    <span class="ins-card-arr">
                      Read more
                      <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
                    </span>
                  </div>
                </a>
              )
            })}
          </div>
        )}
      </div>
    </section>

  </main>
  <Footer />
  <ClientEffects />
</BaseLayout>

<style>
/* Hero */
.ins-hero {
  padding-top: calc(var(--sv) + 80px);
  background: var(--bg-dark);
  position: relative; overflow: hidden;
}
.ins-hero-wrap { position: relative; z-index: 2; max-width: 760px; }
.ins-hero h1 { color: #fff; margin-bottom: 20px; }
.ins-hero h1 em { color: var(--gold-pale); }

/* Grid */
.ins-empty { font-size:17px; color:var(--text-3); padding:80px 0; text-align:center; }
.ins-grid {
  display: grid;
  grid-template-columns: repeat(3, 1fr);
  gap: 28px;
}

/* Card */
.ins-card {
  background: var(--bg);
  border: 1px solid var(--bg-4);
  text-decoration: none; color: inherit;
  display: flex; flex-direction: column;
  overflow: hidden;
  transition: box-shadow .28s, border-color .28s, transform .28s;
}
.ins-card:hover {
  box-shadow: var(--shadow);
  border-color: var(--gold-border);
  transform: translateY(-3px);
}

/* Image */
.ins-card-img {
  width: 100%; aspect-ratio: 16/9; overflow: hidden;
  background: var(--bg-3); position: relative; flex-shrink: 0;
}
.ins-card-img img {
  width: 100%; height: 100%; object-fit: cover;
  transition: transform .5s ease;
}
.ins-card:hover .ins-card-img img { transform: scale(1.05); }
.ins-card-cat {
  position: absolute; top: 12px; left: 12px;
  font-family: var(--FL); font-size: 9px; letter-spacing: 2.5px;
  background: rgba(0,0,0,.55); color: #fff;
  padding: 4px 10px; backdrop-filter: blur(4px);
}

/* Body */
.ins-card-body { padding: 24px 24px 22px; display: flex; flex-direction: column; flex: 1; }
.ins-card-date {
  font-family: var(--FL); font-size: 9px; letter-spacing: 2px;
  color: var(--text-muted); margin-bottom: 10px;
}
.ins-card-title {
  font-family: var(--FD); font-size: 20px; font-weight: 400;
  color: var(--text); margin-bottom: 10px; line-height: 1.3;
}
.ins-card:hover .ins-card-title { color: var(--gold); }
.ins-card-sum {
  font-size: 14px; color: var(--text-3); line-height: 1.75;
  flex: 1; margin-bottom: 16px;
  display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
}
.ins-card-arr {
  display: flex; align-items: center; gap: 6px;
  font-family: var(--FL); font-size: 10px; letter-spacing: 2px;
  color: var(--gold); margin-top: auto;
  opacity: 0; transform: translateX(-6px);
  transition: opacity .3s, transform .3s;
}
.ins-card:hover .ins-card-arr { opacity: 1; transform: translateX(0); }

@media (max-width: 1100px) { .ins-grid { grid-template-columns: 1fr 1fr; } }
@media (max-width: 700px)  { .ins-grid { grid-template-columns: 1fr; gap: 20px; } }
</style>
