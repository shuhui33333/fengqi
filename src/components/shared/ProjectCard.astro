---
// src/components/shared/ProjectCard.astro
interface Props {
  title:      string
  subtitle:   string
  location:   string
  status:     string
  highlights: string[]
  href:       string
  category:   string
  image?:     string | null
}
const { title, subtitle, location, status, highlights, href, category, image = null } = Astro.props

const STATUS_COLORS: Record<string,string> = {
  'Active':          '#2D7A3C',
  'In Development':  '#B8912A',
  'Planned':         '#7A8B9A',
}
const statusColor = STATUS_COLORS[status] ?? '#B8912A'

// Default images by category
const DEFAULT_IMGS: Record<string,string> = {
  'Industrial Park': 'https://images.unsplash.com/photo-1565043666747-69f6646db940?w=800&q=80',
  'Logistics':       'https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?w=800&q=80',
  'Agriculture':     'https://images.unsplash.com/photo-1500382017468-9049fed747ef?w=800&q=80',
  'Healthcare':      'https://images.unsplash.com/photo-1559056199-641a0ac8b55e?w=800&q=80',
  'Media':           'https://images.unsplash.com/photo-1611162617474-5b21e879e113?w=800&q=80',
}
const imgSrc = image ?? DEFAULT_IMGS[category] ?? DEFAULT_IMGS['Industrial Park']
---

<a href={href} class="pc">
  <!-- Image -->
  <div class="pc-img">
    <img src={imgSrc} alt={title} loading="lazy" />
    <div class="pc-overlay">
      <span class="pc-cat">{category}</span>
      <span class="pc-status" style={`background:${statusColor}`}>⬤ {status}</span>
    </div>
  </div>

  <!-- Content -->
  <div class="pc-body">
    <h3 class="pc-title">{title}</h3>
    <p class="pc-sub">{subtitle}</p>
    <p class="pc-loc">
      <svg width="12" height="12" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M12 22s-8-9.2-8-13a8 8 0 0 1 16 0c0 3.8-8 13-8 13z"/><circle cx="12" cy="9" r="3"/></svg>
      {location}
    </p>
    <ul class="pc-hl">
      {highlights.slice(0, 3).map(h => <li>{h}</li>)}
    </ul>
    <span class="pc-arr">
      <span>View Project</span>
      <svg width="14" height="14" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </span>
  </div>
</a>

<style>
.pc {
  background: var(--bg); text-decoration: none; color: inherit;
  display: flex; flex-direction: column;
  border: 1px solid var(--bg-4);
  overflow: hidden;
  transition: box-shadow .28s, border-color .28s, transform .28s;
}
.pc:hover {
  box-shadow: var(--shadow);
  border-color: var(--gold-border);
  transform: translateY(-3px);
}

/* Image */
.pc-img { width:100%; aspect-ratio:16/9; overflow:hidden; position:relative; background:var(--bg-3); }
.pc-img img { width:100%; height:100%; object-fit:cover; transition:transform .5s ease; }
.pc:hover .pc-img img { transform:scale(1.05); }
.pc-overlay {
  position:absolute; top:0; left:0; right:0;
  display:flex; justify-content:space-between; align-items:flex-start;
  padding:14px 16px;
  background: linear-gradient(180deg, rgba(0,0,0,.4) 0%, transparent 100%);
}
.pc-cat {
  font-family:var(--FL); font-size:9px; letter-spacing:2.5px;
  color:#fff; background:rgba(0,0,0,.4); padding:4px 10px; border-radius:1px;
  backdrop-filter: blur(4px);
}
.pc-status {
  font-family:var(--FL); font-size:9px; letter-spacing:1.5px;
  color:#fff; padding:4px 10px; border-radius:1px;
}

/* Content */
.pc-body { padding:28px 28px 24px; display:flex; flex-direction:column; flex:1; }
.pc-title {
  font-family:var(--FD); font-size:22px; font-weight:400;
  color:var(--text); margin-bottom:8px; line-height:1.25;
}
.pc:hover .pc-title { color:var(--gold); }
.pc-sub { font-size:14px; color:var(--text-3); margin-bottom:12px; line-height:1.7; flex:1; font-style:italic; }
.pc-loc {
  display:flex; align-items:center; gap:5px;
  font-size:12px; color:var(--gold-dk); margin-bottom:18px;
  padding-bottom:16px; border-bottom:1px solid var(--bg-4);
}
.pc-loc svg { flex-shrink:0; color:var(--gold); }
.pc-hl { list-style:none; margin-bottom:18px; }
.pc-hl li {
  font-size:13px; color:var(--text-3); padding:5px 0 5px 14px;
  position:relative; border-bottom:1px solid var(--bg-3); line-height:1.5;
}
.pc-hl li::before {
  content:''; position:absolute; left:0; top:50%;
  transform:translateY(-50%); width:5px; height:1.5px; background:var(--gold);
}
.pc-arr {
  display:flex; align-items:center; gap:8px; margin-top:auto;
  font-family:var(--FL); font-size:10px; letter-spacing:2px; color:var(--gold);
  opacity:0; transform:translateX(-8px);
  transition:opacity .3s, transform .3s;
}
.pc:hover .pc-arr { opacity:1; transform:translateX(0); }
</style>
