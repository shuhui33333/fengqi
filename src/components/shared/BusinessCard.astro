---
// src/components/shared/BusinessCard.astro
interface Props {
  num:   string
  en:    string
  name:  string
  body:  string
  href:  string
  tags:  string[]
  image?: string | null  // optional featured image URL
}
const { num, en, name, body, href, tags, image = null } = Astro.props

// Default placeholder images per segment type (Unsplash free-to-use)
const DEFAULTS: Record<string, string> = {
  '01': 'https://images.unsplash.com/photo-1578662996442-48f60103fc96?w=800&q=80',  // industrial / aerial
  '02': 'https://images.unsplash.com/photo-1586528116311-ad8dd3c8310d?w=800&q=80',  // logistics / warehouse
  '03': 'https://images.unsplash.com/photo-1559056199-641a0ac8b55e?w=800&q=80',      // healthcare / wellness
  '04': 'https://images.unsplash.com/photo-1543332164-6e82f355badc?w=800&q=80',      // trade / supply chain
  '05': 'https://images.unsplash.com/photo-1500382017468-9049fed747ef?w=800&q=80',   // agriculture / fields
  '06': 'https://images.unsplash.com/photo-1518186285589-2f7649de83e0?w=800&q=80',  // digital / tech
}
const imgSrc = image ?? DEFAULTS[num] ?? DEFAULTS['01']
---

<a href={href} class="bc cbar">
  <!-- Featured image -->
  <div class="bc-img">
    <img src={imgSrc} alt={name} loading="lazy" />
  </div>

  <!-- Content -->
  <div class="bc-body">
    <div class="cidx">{num}</div>
    <p class="bc-en">{en}</p>
    <h3 class="bc-name">{name}</h3>
    <p class="bc-text">{body}</p>
    <div class="bc-tags">
      {tags.map(t => <span>{t}</span>)}
    </div>
    <span class="bc-arr" aria-hidden="true">
      <span>Learn More</span>
      <svg width="16" height="16" viewBox="0 0 16 16" fill="none"><path d="M3 8h10M9 4l4 4-4 4" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round"/></svg>
    </span>
  </div>
</a>

<style>
.bc {
  background: var(--bg);
  text-decoration: none; color: inherit;
  display: flex; flex-direction: column;
  border: 1px solid var(--bg-4);
  overflow: hidden;
  transition: box-shadow .28s, border-color .28s, transform .28s;
}
.bc:hover {
  box-shadow: var(--shadow);
  border-color: var(--gold-border);
  transform: translateY(-3px);
}
.bc::before { border-radius: 0; }  /* override ctop default */

/* Image */
.bc-img {
  width: 100%; aspect-ratio: 16/9; overflow: hidden;
  background: var(--bg-3);
}
.bc-img img {
  width: 100%; height: 100%; object-fit: cover;
  transition: transform .5s ease;
}
.bc:hover .bc-img img { transform: scale(1.05); }

/* Body */
.bc-body { padding: 32px 28px; display: flex; flex-direction: column; flex: 1; }

.bc-en {
  font-family: var(--FL); font-size: 9px; letter-spacing: 3px;
  color: var(--gold-dk); margin-bottom: 8px; text-transform: uppercase;
}
.bc-name {
  font-family: var(--FD); font-size: 24px; font-weight: 400;
  color: var(--text); margin-bottom: 12px; line-height: 1.25;
}
.bc:hover .bc-name { color: var(--gold); }
.bc-text {
  font-size: 15px; line-height: 1.8; color: var(--text-3);
  flex: 1; margin-bottom: 20px;
}
.bc-tags { display: flex; flex-wrap: wrap; gap: 6px; margin-bottom: 20px; }
.bc-tags span {
  font-family: var(--FL); font-size: 9px; letter-spacing: 1.5px;
  border: 1px solid var(--gold-border); color: var(--gold-dk);
  padding: 3px 10px; background: var(--gold-faint);
}
.bc-arr {
  display: flex; align-items: center; gap: 8px;
  font-family: var(--FL); font-size: 10px; letter-spacing: 2px;
  color: var(--gold);
  opacity: 0; transform: translateX(-8px);
  transition: opacity .3s, transform .3s;
}
.bc:hover .bc-arr { opacity: 1; transform: translateX(0); }
</style>
