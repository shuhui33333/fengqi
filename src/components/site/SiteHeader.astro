

---
import { navigation } from '../../data/navigation';

const pathname = Astro.url.pathname;

const isActive = (href: string) => {
  if (href === '/') return pathname === '/';
  return pathname.startsWith(href);
};
---

<nav>
  <div class="nav-inner">
    <a href="/" class="nav-logo" aria-label="Fengqi Group Home">
      <span class="nav-logo-mark"></span>

      <span class="nav-logo-text">
        <span class="nav-logo-title">FENGQI GROUP</span>
        <span class="nav-logo-subtitle">Industrial · Platform · Technology</span>
      </span>
    </a>

    <div class="nav-right">
      <div class="nav-links" aria-label="Primary navigation">
        {navigation.map((item) => (
          <a
            href={item.href}
            class={isActive(item.href) ? 'active' : ''}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))}
      </div>

      <a href="/contact" class="nav-cta">
        Contact
      </a>

      <button
        class="nav-toggle"
        type="button"
        aria-label="Open menu"
        aria-expanded="false"
        aria-controls="mobile-menu"
      >
        <span></span>
        <span></span>
      </button>
    </div>
  </div>

  <div id="mobile-menu" class="mobile-menu" aria-hidden="true">
    <div class="mobile-menu-inner">
      <div class="mobile-menu-links">
        {navigation.map((item) => (
          <a
            href={item.href}
            class={isActive(item.href) ? 'active' : ''}
            aria-current={isActive(item.href) ? 'page' : undefined}
          >
            {item.label}
          </a>
        ))}
      </div>

      <a href="/contact" class="mobile-menu-cta">Contact Us</a>
    </div>
  </div>
</nav>

<script is:inline>
  const nav = document.querySelector('nav');
  const toggle = document.querySelector('.nav-toggle');
  const mobileMenu = document.getElementById('mobile-menu');

  if (toggle && mobileMenu && nav) {
    const openMenu = () => {
      toggle.setAttribute('aria-expanded', 'true');
      mobileMenu.setAttribute('aria-hidden', 'false');
      nav.classList.add('menu-open');
      document.body.style.overflow = 'hidden';
    };

    const closeMenu = () => {
      toggle.setAttribute('aria-expanded', 'false');
      mobileMenu.setAttribute('aria-hidden', 'true');
      nav.classList.remove('menu-open');
      document.body.style.overflow = '';
    };

    toggle.addEventListener('click', () => {
      const expanded = toggle.getAttribute('aria-expanded') === 'true';
      if (expanded) {
        closeMenu();
      } else {
        openMenu();
      }
    });

    mobileMenu.querySelectorAll('a').forEach((link) => {
      link.addEventListener('click', () => {
        closeMenu();
      });
    });

    window.addEventListener('resize', () => {
      if (window.innerWidth > 700) {
        closeMenu();
      }
    });
  }
</script>

<style>
  .nav-right {
    display: flex;
    align-items: center;
    gap: 18px;
  }

  .nav-links a.active {
    color: var(--gold-light);
  }

  .nav-links a.active::after {
    transform: scaleX(1);
  }

  .nav-cta {
    display: inline-flex;
    align-items: center;
    justify-content: center;
    min-height: 42px;
    padding: 0 18px;
    border-radius: 999px;
    border: 1px solid rgba(198, 168, 106, 0.3);
    background: linear-gradient(
      135deg,
      rgba(198, 168, 106, 0.16),
      rgba(198, 168, 106, 0.06)
    );
    color: var(--gold-light);
    font-size: 0.9rem;
    font-weight: 500;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    transition:
      transform 0.25s ease,
      border-color 0.25s ease,
      background 0.25s ease,
      box-shadow 0.25s ease;
  }

  .nav-cta:hover {
    transform: translateY(-2px);
    border-color: rgba(198, 168, 106, 0.52);
    background: linear-gradient(
      135deg,
      rgba(198, 168, 106, 0.24),
      rgba(198, 168, 106, 0.1)
    );
    box-shadow: 0 10px 24px rgba(198, 168, 106, 0.14);
  }

  .nav-toggle {
    display: none;
    position: relative;
    width: 44px;
    height: 44px;
    padding: 0;
    border: 1px solid rgba(198, 168, 106, 0.24);
    border-radius: 999px;
    background: rgba(255, 255, 255, 0.02);
    cursor: pointer;
    transition:
      border-color 0.25s ease,
      background 0.25s ease,
      transform 0.25s ease;
  }

  .nav-toggle:hover {
    transform: translateY(-1px);
    border-color: rgba(198, 168, 106, 0.5);
    background: rgba(198, 168, 106, 0.06);
  }

  .nav-toggle span {
    position: absolute;
    left: 50%;
    width: 16px;
    height: 1.5px;
    background: var(--gold-light);
    transform: translateX(-50%);
    transition:
      transform 0.25s ease,
      opacity 0.25s ease,
      top 0.25s ease;
  }

  .nav-toggle span:first-child {
    top: 17px;
  }

  .nav-toggle span:last-child {
    top: 25px;
  }

  nav.menu-open .nav-toggle span:first-child {
    top: 21px;
    transform: translateX(-50%) rotate(45deg);
  }

  nav.menu-open .nav-toggle span:last-child {
    top: 21px;
    transform: translateX(-50%) rotate(-45deg);
  }

  .mobile-menu {
    display: none;
  }

  @media (max-width: 900px) {
    .nav-links {
      gap: 16px;
    }

    .nav-links a {
      font-size: 0.82rem;
      letter-spacing: 0.06em;
    }

    .nav-cta {
      padding: 0 16px;
      font-size: 0.82rem;
    }
  }

  @media (max-width: 700px) {
    .nav-cta {
      display: none;
    }

    .nav-toggle {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      flex: 0 0 auto;
    }

    .mobile-menu {
      display: block;
      position: fixed;
      top: var(--nav-height);
      left: 0;
      width: 100%;
      height: calc(100vh - var(--nav-height));
      padding: 0 14px 14px;
      opacity: 0;
      visibility: hidden;
      pointer-events: none;
      transition:
        opacity 0.25s ease,
        visibility 0.25s ease;
    }

    nav.menu-open .mobile-menu {
      opacity: 1;
      visibility: visible;
      pointer-events: auto;
    }

    .mobile-menu-inner {
      height: 100%;
      border: 1px solid rgba(198, 168, 106, 0.16);
      border-radius: 24px;
      background:
        linear-gradient(180deg, rgba(18, 18, 18, 0.96), rgba(10, 10, 10, 0.98));
      backdrop-filter: blur(18px);
      box-shadow: 0 24px 60px rgba(0, 0, 0, 0.36);
      padding: 28px 22px;
      display: flex;
      flex-direction: column;
      justify-content: space-between;
      gap: 24px;
    }

    .mobile-menu-links {
      display: grid;
      gap: 10px;
    }

    .mobile-menu-links a {
      display: block;
      padding: 14px 16px;
      border: 1px solid rgba(198, 168, 106, 0.1);
      border-radius: 16px;
      color: var(--cream-soft);
      background: rgba(255, 255, 255, 0.02);
      font-size: 0.96rem;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      transition:
        border-color 0.25s ease,
        background 0.25s ease,
        color 0.25s ease,
        transform 0.25s ease;
    }

    .mobile-menu-links a:hover,
    .mobile-menu-links a.active {
      color: var(--gold-light);
      border-color: rgba(198, 168, 106, 0.32);
      background: rgba(198, 168, 106, 0.06);
      transform: translateY(-1px);
    }

    .mobile-menu-cta {
      display: inline-flex;
      align-items: center;
      justify-content: center;
      min-height: 50px;
      width: 100%;
      border-radius: 999px;
      background: linear-gradient(135deg, var(--gold-light), var(--gold));
      color: #111;
      font-size: 0.92rem;
      font-weight: 600;
      letter-spacing: 0.08em;
      text-transform: uppercase;
      box-shadow: 0 12px 28px rgba(198, 168, 106, 0.22);
    }
  }
</style>