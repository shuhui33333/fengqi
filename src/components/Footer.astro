---
// src/components/Footer.astro
---
<footer id="site-footer">
  <div class="ft-top">
    <div class="wrap ft-top-inner">
      <div class="ft-brand">
        <a href="/" class="ft-logo" aria-label="Fengqi Group">
          <img src="/images/logo/logo-circle.png" alt="Fengqi" class="ft-logo-img" />
          <div>
            <div class="ft-logo-name">FENGQI GROUP</div>
            <span class="ft-logo-cn">丰麒集团有限公司</span>
          </div>
        </a>
        <p class="ft-desc">A cross-border industrial group connecting China and Southeast Asia through agriculture, logistics, industrial parks, trade and digital systems.</p>
        <p class="ft-motto">丰行天下 · 麒通四海</p>
        <a href="/documents/public-infopack.pdf" class="ft-dl" download>⬇ Download Company Profile</a>
      </div>

      <div>
        <p class="ft-col-title">BUSINESS</p>
        <nav class="ft-links">
          <a href="/business#parks">Industrial Parks</a>
          <a href="/business#logistics">Logistics & Supply Chain</a>
          <a href="/business#healthcare">Healthcare & Wellness</a>
          <a href="/business#trade">Trade & Distribution</a>
          <a href="/business#agriculture">Agriculture & Eco-Tech</a>
          <a href="/business#digital">Digital Systems</a>
        </nav>
      </div>

      <div>
        <p class="ft-col-title">PROJECTS</p>
        <nav class="ft-links">
          <a href="/projects/kuantan-halal-park">Kuantan Halal Park</a>
          <a href="/projects/indonesia-fengjie-logistics">Fengjie Logistics</a>
          <a href="/projects/zengcheng-ecological-space">Zengcheng Eco Space</a>
          <a href="/projects/broiler-chicken-malaysia">Agricultural Land — Malaysia</a>
        </nav>
        <p class="ft-col-title" style="margin-top:32px">COMPANY</p>
        <nav class="ft-links">
          <a href="/about">About Fengqi</a>
          <a href="/about#team">Leadership</a>
          <a href="/insights">Insights</a>
          <a href="/partnership">Partnership</a>
          <a href="/contact">Contact</a>
        </nav>
      </div>

      <div>
        <p class="ft-col-title">GLOBAL OFFICES</p>
        <nav class="ft-links">
          <a href="/contact">Hong Kong · Group HQ</a>
          <a href="/contact">Malaysia · Kuantan</a>
          <a href="/contact">Indonesia · Jakarta</a>
          <a href="/contact">China · Guangzhou</a>
        </nav>
        <div class="ft-badge">
          <p class="ft-badge-lbl">ESTABLISHED</p>
          <p class="ft-badge-val">2014 · Hong Kong</p>
        </div>
      </div>
    </div>
  </div>

  <div class="ft-bottom">
    <div class="wrap ft-bottom-inner">
      <span class="ft-copy">© 2025 Fengqi Group Limited · All Rights Reserved</span>
      <span class="ft-legal">Cross-Border Industrial Platform · Est. 2014</span>
    </div>
  </div>
</footer>

<style>
#site-footer { background: var(--bg-dark); color: rgba(255,255,255,.75); }

.ft-top { border-top: 1px solid rgba(184,145,42,.25); padding: 72px 0 56px; }
.ft-top-inner {
  display: grid;
  grid-template-columns: 1.5fr 1fr 1fr 1fr;
  gap: 56px;
}

/* Brand */
.ft-logo { display:flex; align-items:center; gap:16px; text-decoration:none; margin-bottom:20px; }
.ft-logo-img { width: 52px; height: 52px; object-fit:contain; }
.ft-logo-name { font-family:var(--FL); font-size:15px; color:var(--gold-pale); letter-spacing:3px; }
.ft-logo-cn   { font-family:var(--FD); font-size:12px; color:var(--gold-dk); letter-spacing:2px; display:block; margin-top:4px; font-style:italic; }
.ft-desc  { font-size:14px; color:rgba(255,255,255,.6); line-height:1.85; margin-bottom:18px; }
.ft-motto { font-family:var(--FD); font-size:14px; font-style:italic; color:var(--gold-pale); letter-spacing:2px; margin-bottom:18px; }
.ft-dl {
  font-family:var(--FL); font-size:10px; letter-spacing:2px;
  color:rgba(255,255,255,.5); border:1px solid rgba(255,255,255,.2);
  padding:9px 16px; display:inline-block; transition:all .25s;
}
.ft-dl:hover { border-color:var(--gold-pale); color:var(--gold-pale); }

/* Column titles */
.ft-col-title {
  font-family:var(--FL); font-size:10px; letter-spacing:4px;
  color:var(--gold-pale); margin-bottom:16px; padding-bottom:10px;
  border-bottom:1px solid rgba(184,145,42,.25);
}
.ft-links { display:flex; flex-direction:column; }
.ft-links a {
  font-size:13px; color:rgba(255,255,255,.55);
  padding:6px 0; transition:color .25s; line-height:1.5;
  border-bottom: 1px solid rgba(255,255,255,.05);
}
.ft-links a:hover { color:var(--gold-pale); }

/* Badge */
.ft-badge { margin-top:28px; padding:18px 20px; border:1px solid rgba(184,145,42,.25); }
.ft-badge-lbl { font-family:var(--FL); font-size:9px; letter-spacing:3px; color:var(--gold-pale); margin-bottom:6px; }
.ft-badge-val { font-family:var(--FD); font-size:16px; color:rgba(255,255,255,.7); }

/* Bottom bar */
.ft-bottom { border-top:1px solid rgba(255,255,255,.08); padding:24px 0; }
.ft-bottom-inner { display:flex; justify-content:space-between; align-items:center; }
.ft-copy  { font-family:var(--FL); font-size:10px; letter-spacing:2px; color:rgba(255,255,255,.3); }
.ft-legal { font-size:12px; color:rgba(255,255,255,.3); }

@media (max-width:1100px) { .ft-top-inner { grid-template-columns:1fr 1fr; gap:36px; } }
@media (max-width:700px)  {
  .ft-top-inner { grid-template-columns:1fr; }
  .ft-bottom-inner { flex-direction:column; gap:10px; text-align:center; }
}
</style>
