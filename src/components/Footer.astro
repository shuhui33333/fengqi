---
// src/components/Footer.astro
// Light gold background · black / deep brown / gold text
---
<footer id="site-footer">
  <div class="ft-top">
    <div class="wrap ft-top-inner">

      <!-- Brand -->
      <div class="ft-brand">
        <a href="/" class="ft-logo" aria-label="Fengqi Group">
          <img src="/images/logo/logo-circle.png" alt="Fengqi" class="ft-logo-img" />
          <div>
            <div class="ft-logo-name">FENGQI GROUP</div>
            <span class="ft-logo-cn">丰麒集团有限公司</span>
          </div>
        </a>
        <p class="ft-desc">A cross-border industrial group connecting China and Southeast Asia through agriculture, logistics, industrial parks, trade and digital systems.</p>
        <p class="ft-motto">丰行天下 · 麒通四海</p>
        <a href="/documents/public-infopack.pdf" class="ft-dl" download>⬇ Download Company Profile</a>
      </div>

      <!-- Business -->
      <div>
        <p class="ft-col-title">BUSINESS</p>
        <nav class="ft-links">
          <a href="/business#parks">Industrial Parks</a>
          <a href="/business#logistics">Logistics & Supply Chain</a>
          <a href="/business#healthcare">Healthcare & Wellness</a>
          <a href="/business#trade">Trade & Distribution</a>
          <a href="/business#agriculture">Agriculture & Eco-Tech</a>
          <a href="/business#digital">Digital Systems</a>
        </nav>
      </div>

      <!-- Projects + Company -->
      <div>
        <p class="ft-col-title">PROJECTS</p>
        <nav class="ft-links">
          <a href="/projects/kuantan-halal-park">Kuantan Halal Park</a>
          <a href="/projects/indonesia-fengjie-logistics">Fengjie Logistics</a>
          <a href="/projects/zengcheng-ecological-space">Zengcheng Eco Space</a>
          <a href="/projects/broiler-chicken-malaysia">Agricultural Land — Malaysia</a>
        </nav>
        <p class="ft-col-title" style="margin-top:28px">COMPANY</p>
        <nav class="ft-links">
          <a href="/about">About Fengqi</a>
          <a href="/about#team">Leadership</a>
          <a href="/insights">Insights</a>
          <a href="/partnership">Partnership</a>
          <a href="/contact">Contact</a>
        </nav>
      </div>

      <!-- Offices -->
      <div>
        <p class="ft-col-title">GLOBAL OFFICES</p>
        <nav class="ft-links">
          <a href="/contact">Hong Kong · Group HQ</a>
          <a href="/contact">Malaysia · Kuantan</a>
          <a href="/contact">Indonesia · Jakarta</a>
          <a href="/contact">China · Guangzhou</a>
        </nav>
        <div class="ft-contact">
          <p class="ft-col-title" style="margin-top:28px">CONTACT</p>
          <a href="mailto:info@fengqi-global.com" class="ft-email">info@fengqi-global.com</a>
        </div>
      </div>

    </div>
  </div>

  <div class="ft-bottom">
    <div class="wrap ft-bottom-inner">
      <span class="ft-copy">© 2025 Fengqi Group Limited · All Rights Reserved</span>
    </div>
  </div>
</footer>

<style>
/* ── Light gold palette for footer ── */
:root {
  --ft-bg:       #F5EDD6;   /* warm pale gold */
  --ft-bg-2:     #EEE0BA;   /* slightly deeper for bottom bar */
  --ft-border:   rgba(184,145,42,.25);
  --ft-text:     #1A1814;   /* near-black — strong contrast */
  --ft-text-2:   #3D3020;   /* dark brown body */
  --ft-text-3:   #6B5832;   /* mid-brown muted */
  --ft-gold:     #8A5F10;   /* deep gold on pale bg — readable */
}

#site-footer { background: var(--ft-bg); border-top: 2px solid var(--ft-border); }

.ft-top { padding: 64px 0 52px; }
.ft-top-inner {
  display: grid;
  grid-template-columns: 1.5fr 1fr 1fr 1fr;
  gap: 52px;
}

/* Brand */
.ft-logo { display:flex; align-items:center; gap:16px; text-decoration:none; margin-bottom:20px; }
.ft-logo-img { width:52px; height:52px; object-fit:contain; }
.ft-logo-name { font-family:var(--FL); font-size:15px; color:var(--ft-text); letter-spacing:3px; font-weight:600; }
.ft-logo-cn   { font-family:var(--FD); font-size:12px; color:var(--ft-gold); letter-spacing:2px; display:block; margin-top:4px; font-style:italic; }
.ft-desc  { font-family:var(--FB); font-size:14px; color:var(--ft-text-2); line-height:1.85; margin-bottom:16px; }
.ft-motto { font-family:var(--FD); font-size:15px; font-style:italic; color:var(--ft-gold); letter-spacing:2px; margin-bottom:18px; }
.ft-dl {
  font-family:var(--FL); font-size:10px; letter-spacing:2px;
  color:var(--ft-gold); border:1.5px solid var(--ft-border);
  padding:9px 16px; display:inline-block; transition:all .25s;
  font-weight:500;
}
.ft-dl:hover { border-color:var(--ft-gold); background:rgba(184,145,42,.1); }

/* Column titles */
.ft-col-title {
  font-family:var(--FL); font-size:10px; letter-spacing:4px;
  color:var(--ft-text); margin-bottom:14px; padding-bottom:10px;
  border-bottom:1.5px solid var(--ft-border); font-weight:600;
}

/* Links */
.ft-links { display:flex; flex-direction:column; }
.ft-links a {
  font-family:var(--FB); font-size:13.5px; color:var(--ft-text-2);
  padding:6px 0; transition:color .25s; line-height:1.5;
  border-bottom:1px solid rgba(184,145,42,.12);
}
.ft-links a:hover { color:var(--ft-gold); }

/* Contact email */
.ft-email {
  display:block; font-family:var(--FL); font-size:11px; letter-spacing:1px;
  color:var(--ft-gold); font-weight:500; margin-top:6px; text-decoration:none;
  transition:color .25s;
}
.ft-email:hover { color:var(--ft-text); }

/* Bottom bar */
.ft-bottom { background:var(--ft-bg-2); border-top:1px solid var(--ft-border); padding:20px 0; }
.ft-bottom-inner { display:flex; justify-content:center; align-items:center; }
.ft-copy { font-family:var(--FL); font-size:10px; letter-spacing:2px; color:var(--ft-text-3); }

@media (max-width:1100px) { .ft-top-inner { grid-template-columns:1fr 1fr; gap:36px; } }
@media (max-width:700px)  {
  .ft-top-inner { grid-template-columns:1fr; }
  .ft-bottom-inner { text-align:center; }
}
</style>
