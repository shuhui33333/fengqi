---
const heroData = {
  brand: {
    logo: "/logo.png",
    alt: "Fengqi Group Limited",
  },
  eyebrow: "GLOBAL HALAL INDUSTRY PLATFORM",
  title: {
    line1: "The Infrastructure",
    line2: "Behind",
    accent: "Global",
    line3: "Halal Trade.",
  },
  description:
    "Fengqi connects cross-border industrial resources, digital capabilities, halal certification pathways, and integrated platform development — building a coordinated ecosystem across agriculture, food processing, trade, healthcare, and smart industry.",
  primaryCta: {
    label: "Explore Our Platform",
    href: "/platforms",
  },
  secondaryCta: {
    label: "Partner With Us",
    href: "/partnership",
  },
  stats: [
    { value: "Multi-Sector", label: "Integrated Business Layout" },
    { value: "Cross-Border", label: "China–Malaysia Platform Synergy" },
    { value: "Digital + Physical", label: "Industrial Infrastructure Model" },
  ],
};
---

<section class="hero-home">
  <div class="geo-bg" aria-hidden="true"></div>
  <div class="hero-overlay" aria-hidden="true"></div>

  <div class="hero-shell">
    <div class="hero-brand reveal d1">
      <a href="/" class="hero-brand-link" aria-label="Fengqi Group Limited home">
        <img
          src={heroData.brand.logo}
          alt={heroData.brand.alt}
          class="hero-brand-logo"
          loading="eager"
          decoding="async"
        />
      </a>
    </div>

    <div class="hero-copy">
      <div class="hero-kicker reveal d2">
        <span class="gold-rule"></span>
        <p class="label">{heroData.eyebrow}</p>
      </div>

      <h1 class="heading hero-title reveal d3">
        {heroData.title.line1}<br />
        {heroData.title.line2} <em>{heroData.title.accent}</em><br />
        {heroData.title.line3}
      </h1>

      <p class="hero-description reveal d4">
        {heroData.description}
      </p>

      <div class="hero-actions reveal d5">
        <a href={heroData.primaryCta.href} class="btn-primary">
          {heroData.primaryCta.label}
        </a>
        <a href={heroData.secondaryCta.href} class="btn-ghost">
          {heroData.secondaryCta.label}
        </a>
      </div>

      <div class="hero-stats reveal d5" aria-label="Platform highlights">
        {heroData.stats.map((item) => (
          <div class="hero-stat">
            <h3>{item.value}</h3>
            <p>{item.label}</p>
          </div>
        ))}
      </div>
    </div>
  </div>
</section>