---
const hero = {
  brand: {
    logo: "/logo.png",
    alt: "Fengqi Group Limited",
  },
  eyebrow: "GLOBAL HALAL INDUSTRY PLATFORM",
  title: {
    line1: "The Infrastructure",
    line2Prefix: "Behind",
    line2Emphasis: "Global",
    line3: "Halal Trade.",
  },
  description: {
    prefix: "Fengqi connects",
    highlight1: "China’s unmatched production capacity",
    middle: "with",
    highlight2: "Malaysia’s JAKIM certification authority",
    suffix: "— delivering trusted halal food to 2 billion Muslims across 100+ markets.",
  },
  primaryCta: {
    text: "EXPLORE OUR PLATFORM",
    href: "/platforms",
  },
  secondaryCta: {
    text: "PARTNER WITH US",
    href: "/partnership",
  },
};
---

<section class="home-hero">
  <div class="geo-bg" aria-hidden="true"></div>
  <div class="home-hero__shade" aria-hidden="true"></div>

  <div class="home-hero__inner">
    <div class="home-hero__brand reveal d1">
      <a href="/" class="home-hero__brand-link" aria-label="Fengqi Group Limited home">
        <img
          src={hero.brand.logo}
          alt={hero.brand.alt}
          class="home-hero__logo"
          loading="eager"
          decoding="async"
        />
      </a>
    </div>

    <div class="home-hero__content">
      <div class="home-hero__intro reveal d2">
        <span class="gold-rule" aria-hidden="true"></span>
        <p class="label">{hero.eyebrow}</p>
      </div>

      <h1 class="heading home-hero__title reveal d3">
        <span>{hero.title.line1}</span>
        <span>
          {hero.title.line2Prefix} <em>{hero.title.line2Emphasis}</em>
        </span>
        <span>{hero.title.line3}</span>
      </h1>

      <p class="home-hero__description reveal d4">
        {hero.description.prefix} <strong>{hero.description.highlight1}</strong> {hero.description.middle}{" "}
        <strong>{hero.description.highlight2}</strong> {hero.description.suffix}
      </p>

      <div class="home-hero__actions reveal d4">
        <a href={hero.primaryCta.href} class="btn-primary">
          {hero.primaryCta.text}
        </a>
        <a href={hero.secondaryCta.href} class="btn-ghost">
          {hero.secondaryCta.text}
        </a>
      </div>
    </div>
  </div>
</section>