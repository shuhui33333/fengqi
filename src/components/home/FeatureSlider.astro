---
// src/components/home/FeatureSlider.astro — metrics strip, light theme
---
<div class="met-bar">
  <div class="wrap met-inner">
    {[
      { num:'2014',  lbl:'FOUNDED'              },
      { num:'3',     lbl:'COUNTRIES ACTIVE'     },
      { num:'6',     lbl:'BUSINESS SEGMENTS'    },
      { num:'830ac', lbl:'KUANTAN HALAL PARK'   },
      { num:'145M',  lbl:'JAVA LOGISTICS REACH' },
      { num:'80+',   lbl:'HALAL CERT NATIONS'   },
    ].map((m, i) => (
      <div class={`met reveal d${i}`}>
        <div class="met-num">{m.num}</div>
        <div class="met-lbl">{m.lbl}</div>
      </div>
    ))}
  </div>
</div>

<style>
.met-bar { background: var(--bg-3); border-top:1px solid var(--bg-4); border-bottom:1px solid var(--bg-4); }
.met-inner {
  display: grid; grid-template-columns: repeat(6,1fr);
  gap: 1px; background: var(--bg-4);
}
.met {
  background: var(--bg-3); padding: 34px 18px; text-align: center;
  transition: background .25s;
}
.met:hover { background: var(--bg-2); }
.met-num {
  font-family: var(--FL); font-size: 36px; font-weight: 600;
  color: var(--gold); line-height: 1; margin-bottom: 8px;
}
.met-lbl {
  font-family: var(--FL); font-size: 9px; letter-spacing: 2.5px;
  color: var(--text-3); font-weight: 400;
}
@media (max-width:1100px) { .met-inner { grid-template-columns:repeat(3,1fr); } }
@media (max-width:700px)  { .met-inner { grid-template-columns:repeat(2,1fr); } }
</style>
