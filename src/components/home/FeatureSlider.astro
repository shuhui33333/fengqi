---
// src/components/home/FeatureSlider.astro — metrics strip, white theme
---
<div class="met-bar">
  <div class="wrap met-inner">
    {[
      { num:'2014',  lbl:'FOUNDED'              },
      { num:'3',     lbl:'COUNTRIES ACTIVE'     },
      { num:'6',     lbl:'BUSINESS SEGMENTS'    },
      { num:'800ac', lbl:'KUANTAN HALAL PARK'   },
      { num:'145M',  lbl:'JAVA LOGISTICS REACH' },
      { num:'80+',   lbl:'HALAL CERT NATIONS'   },
    ].map((m,i) => (
      <div class={`met reveal d${i}`}>
        <div class="met-num">{m.num}</div>
        <div class="met-lbl">{m.lbl}</div>
      </div>
    ))}
  </div>
</div>
<style>
.met-bar { background: var(--bg-dark); }
.met-inner {
  display: grid; grid-template-columns: repeat(6,1fr);
  gap: 1px; background: rgba(255,255,255,.08);
}
.met {
  background: var(--bg-dark); padding: 36px 20px; text-align: center;
  transition: background .25s;
}
.met:hover { background: var(--bg-dark-2); }
.met-num { font-family:var(--FD); font-size:40px; font-weight:300; color:var(--gold-pale); line-height:1; margin-bottom:7px; }
.met-lbl { font-family:var(--FL); font-size:9px; letter-spacing:2.5px; color:rgba(255,255,255,.5); }
@media (max-width:1100px) { .met-inner { grid-template-columns:repeat(3,1fr); } }
@media (max-width:700px)  { .met-inner { grid-template-columns:repeat(2,1fr); } }
</style>
