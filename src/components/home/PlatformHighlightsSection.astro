---
const platformItems = [
  {
    index: "01",
    title: "Digital Industrial Park Platform",
    description:
      "Building integrated development platforms around smart industry, digital infrastructure, operational systems and international project coordination.",
    points: [
      "Industrial park planning and development",
      "Smart systems and digital operation support",
      "Regional cooperation and cross-border linkage"
    ]
  },
  {
    index: "02",
    title: "Agriculture & Food Supply Platform",
    description:
      "Connecting upstream resources, processing capability, supply collaboration and channel development to support stable, scalable and high-quality sector growth.",
    points: [
      "Agricultural resource integration",
      "Food-related industrial collaboration",
      "Supply chain and market connectivity"
    ]
  },
  {
    index: "03",
    title: "Health & Wellness Platform",
    description:
      "Exploring coordinated models across wellness services, healthcare-related resources, operational systems and long-cycle ecosystem development.",
    points: [
      "Wellness-oriented service scenarios",
      "Healthcare ecosystem connectivity",
      "Integrated destination development"
    ]
  }
];
---

<section class="platform-highlights">
  <div class="container">
    <div class="section-head">
      <div class="section-copy">
        <p class="section-eyebrow">PLATFORM LAYOUT</p>
        <h2>Integrated platforms for diversified development.</h2>
      </div>

      <div class="section-summary">
        <p>
          Fengqi Group advances business growth through platform-oriented
          development, linking industry resources, operational capability,
          digital systems and cross-sector coordination into scalable
          development structures.
        </p>
      </div>
    </div>

    <div class="platform-grid">
      {platformItems.map((item) => (
        <article class="platform-card">
          <div class="card-top">
            <span class="card-index">{item.index}</span>
            <h3>{item.title}</h3>
          </div>

          <p class="card-description">{item.description}</p>

          <ul class="card-points">
            {item.points.map((point) => (
              <li>{point}</li>
            ))}
          </ul>
        </article>
      ))}
    </div>

    <div class="platform-footer">
      <div class="footer-text">
        <p>
          This platform structure enables Fengqi Group to connect project
          development, industrial coordination and implementation capability
          within a more resilient and expandable business framework.
        </p>
      </div>

      <a href="/platforms" class="platform-link">
        View Platform Details
        <span aria-hidden="true">→</span>
      </a>
    </div>
  </div>
</section>

<style>
.platform-highlights {
  position: relative;
  padding: 110px 0;
  background:
    linear-gradient(180deg, #0d0d0d 0%, #121212 100%);
}

.section-head {
  display: grid;
  grid-template-columns: 1.1fr 0.9fr;
  gap: 40px;
  align-items: end;
  margin-bottom: 48px;
}

.section-eyebrow {
  margin: 0 0 14px;
  font-size: 12px;
  letter-spacing: 0.22em;
  color: var(--gold);
}

.section-copy h2 {
  margin: 0;
  max-width: 760px;
  font-family: "Cormorant Garamond", serif;
  font-size: clamp(2.2rem, 4vw, 3.6rem);
  line-height: 1.08;
  font-weight: 500;
  letter-spacing: -0.02em;
  color: #f5f1e8;
}

.section-summary p {
  margin: 0;
  font-size: 15px;
  line-height: 1.9;
  color: rgba(255, 255, 255, 0.7);
}

.platform-grid {
  display: grid;
  grid-template-columns: repeat(3, minmax(0, 1fr));
  gap: 22px;
}

.platform-card {
  position: relative;
  min-height: 100%;
  padding: 28px 26px 26px;
  border: 1px solid rgba(201, 168, 76, 0.14);
  background:
    linear-gradient(180deg, rgba(255,255,255,0.025) 0%, rgba(255,255,255,0.01) 100%);
  transition:
    transform 0.3s ease,
    border-color 0.3s ease,
    background 0.3s ease;
}

.platform-card:hover {
  transform: translateY(-4px);
  border-color: rgba(201, 168, 76, 0.32);
  background:
    linear-gradient(180deg, rgba(255,255,255,0.04) 0%, rgba(255,255,255,0.015) 100%);
}

.card-top {
  display: flex;
  flex-direction: column;
  gap: 18px;
  margin-bottom: 18px;
}

.card-index {
  display: inline-flex;
  align-items: center;
  width: fit-content;
  font-size: 12px;
  line-height: 1;
  letter-spacing: 0.18em;
  color: var(--gold);
  opacity: 0.9;
}

.card-top h3 {
  margin: 0;
  font-size: 24px;
  line-height: 1.28;
  font-weight: 500;
  color: #f5f1e8;
}

.card-description {
  margin: 0 0 22px;
  font-size: 14px;
  line-height: 1.9;
  color: rgba(255, 255, 255, 0.68);
}

.card-points {
  margin: 0;
  padding: 0;
  list-style: none;
  display: grid;
  gap: 12px;
}

.card-points li {
  position: relative;
  padding-left: 18px;
  font-size: 14px;
  line-height: 1.75;
  color: rgba(255, 255, 255, 0.78);
}

.card-points li::before {
  content: "";
  position: absolute;
  left: 0;
  top: 0.7em;
  width: 6px;
  height: 6px;
  border-radius: 50%;
  background: var(--gold);
}

.platform-footer {
  display: flex;
  justify-content: space-between;
  align-items: center;
  gap: 24px;
  margin-top: 36px;
  padding-top: 24px;
  border-top: 1px solid rgba(201, 168, 76, 0.12);
}

.footer-text {
  max-width: 760px;
}

.footer-text p {
  margin: 0;
  font-size: 14px;
  line-height: 1.9;
  color: rgba(255, 255, 255, 0.62);
}

.platform-link {
  display: inline-flex;
  align-items: center;
  gap: 10px;
  white-space: nowrap;
  text-decoration: none;
  font-size: 13px;
  letter-spacing: 0.12em;
  text-transform: uppercase;
  color: #f5f1e8;
  transition: color 0.3s ease, gap 0.3s ease;
}

.platform-link:hover {
  color: var(--gold);
  gap: 14px;
}

@media (max-width: 1024px) {
  .section-head {
    grid-template-columns: 1fr;
    gap: 20px;
  }

  .platform-grid {
    grid-template-columns: 1fr;
  }

  .platform-footer {
    flex-direction: column;
    align-items: flex-start;
  }
}

@media (max-width: 768px) {
  .platform-highlights {
    padding: 80px 0;
  }

  .card-top h3 {
    font-size: 22px;
  }
}
</style>